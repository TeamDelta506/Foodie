# Foodie — environment configuration
#
# Copy this file to .env and fill in your values.
#   cp .env.example .env   (Mac/Linux)
#   copy .env.example .env  (Windows)
#
# .env is gitignored — never commit real keys.

# ---------------------------------------------------------------------------
# Flask
# ---------------------------------------------------------------------------

# Secret key signs session cookies. Use a long random string in production.
# SECRET_KEY=dev-secret-not-for-production

# Database URL. Default points at the db service in Docker Compose.
# DATABASE_URL=postgresql://app:app@db:5432/app

# Edamam Recipe Search API (one team key pair for the whole app — not per user).
# Sign up at https://developer.edamam.com/, create a Recipe Search app, then paste
# Application ID and Application Key here. Share values with teammates via a secure
# channel; never commit .env to git.
# EDAMAM_APP_ID=your-application-id
# EDAMAM_APP_KEY=your-application-key
# Required on some Edamam plans (401 without it). Logged-in users send their Foodie user id;
# guests use this shared id unless you set per-session ids in app code.
# EDAMAM_ACCOUNT_USER=foodie-team
