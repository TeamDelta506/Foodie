+    recipes      = []
+    search_error = None
+
+    if q:
+        try:
+            resp = http.get(
+                EDAMAM_BASE,
+                params={"type": "public", "q": q,
+                        "app_id": EDAMAM_APP_ID, "app_key": EDAMAM_APP_KEY},
+                timeout=EDAMAM_TIMEOUT,
+            )
+
+            if resp.status_code == 429:
+                flash("Recipe search is rate limited — please try again in a moment.")
+                search_error = "rate_limited"
+            elif not resp.ok:
